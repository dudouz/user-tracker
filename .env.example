# Copy to .env and fill in values. Never commit .env.

# PostgreSQL (see docker-compose for local defaults)
DATABASE_URL=postgres://postgres:postgres@localhost:5454/user_tracker

# 32+ random characters; used to sign session JWTs
JWT_SECRET=replace-with-random-32-chars-minimum-generate-securely

# Public site URL (invite links, email). Local: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend (https://resend.com) for transactional email / invites
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_API_KEY=

# PostHog (https://posthog.com) — leave keys empty to disable analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Optional: server capture only; falls back to NEXT_PUBLIC_POSTHOG_KEY if unset
POSTHOG_KEY=

# Arcade MCP Gateway — https://app.arcade.dev/mcp-gateways
# Gateway URL your PostHog (and other) tools are exposed through.
ARCADE_GATEWAY_URL=
# Optional. Only needed if you enable the custom user verifier.
ARCADE_API_KEY=

# OpenAI — powers the /insights chat agent. Get a key at https://platform.openai.com
OPENAI_API_KEY=
